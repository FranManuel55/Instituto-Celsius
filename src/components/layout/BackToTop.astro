---
import { Icon } from 'astro-icon/components';
---

<button
  type="button"
  id="back-to-top"
  class="fixed bottom-6 left-6 z-40 w-11 h-11 bg-surface-raised border border-hairline-strong text-ink rounded-full flex items-center justify-center shadow-soft opacity-0 pointer-events-none transition-all duration-500 ease-out-expo hover:bg-ink hover:text-surface hover:border-ink hover:-translate-y-0.5"
  aria-label="Volver arriba"
>
  <Icon name="lucide:arrow-up" class="w-4 h-4" />
</button>

<script>
  const backToTopBtn = document.getElementById('back-to-top');

  const updateButton = () => {
    if (!backToTopBtn) return;
    if (window.scrollY > 600) {
      backToTopBtn.classList.remove('opacity-0', 'pointer-events-none');
      backToTopBtn.classList.add('opacity-100', 'pointer-events-auto');
    } else {
      backToTopBtn.classList.add('opacity-0', 'pointer-events-none');
      backToTopBtn.classList.remove('opacity-100', 'pointer-events-auto');
    }
  };

  window.addEventListener('scroll', updateButton, { passive: true });

  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
